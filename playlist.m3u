# curl -I test we used for Himalaya to confirm before fiddling.
# ─────────────────────────────────────────────────────────────
#EXTINF:-1 tvg-name="Max HD" group-title="Movies",Max HD
#EXTVLCOPT:http-user-agent=Mozilla/5.0
